# Copy this file to .env and fill in your values

# ElevenLabs — used by api/speak.js (server-side only, never exposed to browser)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: override default voice (Noa — XvfwInXiPC6BcAjGWhmS)
# ELEVENLABS_VOICE_ID=XvfwInXiPC6BcAjGWhmS

# Groq — used by api/chat.js
# GROQ_API_KEY=your_groq_api_key_here

# Nordigen (GoCardless Bank Account Data) — used by api/banking/*.js
# Read-only Open Banking: fetches account balances and transactions.
# Noa NEVER has write access. Your users' money is always safe.
#
# How to get these:
#   1. Sign up free at https://bankaccountdata.gocardless.com
#   2. Go to Dashboard → User Secrets → Create new secret
#   3. Copy Secret ID and Secret Key below
#   4. Add both to your Vercel project: Settings → Environment Variables
#
NORDIGEN_SECRET_ID=your_nordigen_secret_id_here
NORDIGEN_SECRET_KEY=your_nordigen_secret_key_here
