# Copy this file to .env and fill in your values

# ElevenLabs — used by api/speak.js (server-side only, never exposed to browser)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: override default voice (Noa — XvfwInXiPC6BcAjGWhmS)
# ELEVENLABS_VOICE_ID=XvfwInXiPC6BcAjGWhmS

# Groq — used by api/chat.js
# GROQ_API_KEY=your_groq_api_key_here

# Plaid (Open Banking) — used by api/banking/*.js
# Read-only bank data: fetches account balances and transactions via Plaid Link.
# Noa NEVER has write access. Your users' money is always safe.
#
# How to get these:
#   1. Sign up free at https://dashboard.plaid.com
#   2. Go to Team Settings → Keys
#   3. Copy Client ID and Sandbox Secret below
#   4. Add both to your Vercel project: Settings → Environment Variables
#
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_sandbox_secret_here
# Switch to production secret when going live — also update PLAID_BASE in api/banking/provider.js
